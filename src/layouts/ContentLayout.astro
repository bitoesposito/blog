---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Head from "../components/Head.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { Tags } from "../components/ui/tags";
import { formatDate } from "../lib/post";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  /** Stringa già calcolata dalla pagina (es. solo per il blog). */
  readingTime?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  readingTime,
} = Astro.props;
---

<html lang="it">
  <head>
    <Head title={title} description={description} image={heroImage} />
  </head>
  <body>
    <Header />
    <main class="mx-auto flex max-w-3xl flex-col gap-6 px-4 lg:px-0 py-4">
      <article class="flex flex-col gap-6">
        <header class="flex flex-col gap-3">
          <h1 class="text-3xl font-bold leading-tight">{title}</h1>

          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            {readingTime && (
              <>
                <span aria-hidden="true">|</span>
                <span>{readingTime}</span>
              </>
            )}
            {updatedDate && (
              <>
                <span aria-hidden="true">|</span>
                <span>Aggiornato il {formatDate(updatedDate)}</span>
              </>
            )}
          </div>

          <Tags tags={tags} />
        </header>

        {
          heroImage && (
            <Image
              class="w-full rounded-xl"
              width={1020}
              height={510}
              src={heroImage}
              alt=""
            />
          )
        }

        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  .prose {
    line-height: 1.5;
  }
  .prose > * + * {
    margin-top: 1em;
  }
  .prose h2 {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .prose h3 {
    margin-top: 1.25em;
    font-size: 1.125rem;
    font-weight: 600;
  }
  .prose p {
    color: var(--muted-foreground)
  }
  .prose a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.125em;
  }
  .prose ul {
    list-style: disc;
  }
  .prose ol {
    list-style: decimal;
  }
  .prose li + li {
    margin-top: 0.4em;
  }
  .prose blockquote {
    border-left: 3px solid var(--border);
    padding-left: 1em;
    color: var(--muted-foreground);
    font-style: italic;
  }
  .prose code {
    background: var(--muted);
    border-radius: var(--radius-md);
    padding: 0.15em 0.4em;
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  .prose pre {
    background: var(--muted);
    border-radius: var(--radius-lg);
    padding: 1em;
    overflow-x: auto;
  }
  .prose pre code {
    background: transparent;
    padding: 0;
  }
  .prose img {
    border-radius: var(--radius-lg);
  }
</style>
