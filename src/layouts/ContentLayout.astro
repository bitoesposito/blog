---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Head from "../components/Head.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { Tags } from "../components/ui/tags";
import { Icon } from "../components/ui/icon";
import { formatDate } from "../lib/post";
import "../styles/prose.css";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
  readingTime?: string;
  headings?: Heading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  readingTime,
  headings = [],
} = Astro.props;

const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocItems.length >= 2;
---

{/* scroll-pt: header + barra indice (< xl) / solo header (xl+) per gli anchor. */}
<html class="scroll-pt-28 xl:scroll-pt-20" lang="it">
  <head>
    <Head
      title={title}
      description={description}
      image={heroImage}
      ogType="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
      tags={tags}
    />
  </head>
  <body>
    <Header />

    {/*
      Quando lo schermo è troppo stretto per ospitare la sidebar nella gutter
      di sinistra (< xl), l'indice diventa una barra ripiegabile in alto,
      ancorata sotto l'header.
    */}
    {(hasToc || Astro.slots.has("toc-extra")) && (
      <details
        class="toc-top group sticky top-16 z-40 border-b border-border bg-background/80 backdrop-blur-sm xl:hidden"
      >
        <summary class="mx-auto flex max-w-3xl cursor-pointer list-none items-center gap-2 px-4 py-3 text-sm [&::-webkit-details-marker]:hidden">
          {/* Anello che si riempie in base alla posizione di scroll della pagina. */}
          <svg class="size-4 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
            <circle
              class="text-primary/20"
              cx="12"
              cy="12"
              r="10"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            />
            <circle
              id="toc-progress"
              class="text-primary"
              cx="12"
              cy="12"
              r="10"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-dasharray="62.83"
              stroke-dashoffset="62.83"
              transform="rotate(-90 12 12)"
            />
          </svg>
          <span id="toc-current" class="min-w-0 flex-1 truncate font-medium">
            {tocItems[0]?.text ?? "Contenuti del corso"}
          </span>
          <Icon
            name="ChevronDown"
            className="shrink-0 text-muted-foreground transition-transform group-[[open]]:rotate-180"
          />
        </summary>
        <div class="mx-auto flex max-h-[65vh] max-w-3xl flex-col gap-3 overflow-y-auto px-4 pb-3">
          {hasToc && (
            <nav aria-label="Indice del post">
              <TableOfContents items={tocItems} />
            </nav>
          )}
          {/* Su una pagina-corso: elenco dei capitoli per navigare da mobile. */}
          <slot name="toc-extra" />
        </div>
      </details>
    )}

    {/*
      Griglia a 3 colonne: gutter | contenuto | gutter.
      Riga 1: intestazione del post (titolo, meta, navigazione) centrata.
      Riga 2: sidebar di sinistra | corpo | sidebar di destra — le sidebar
      partono quindi sotto l'intestazione, come nel blog legacy.
    */}
    <main
      class="grid grid-cols-[minmax(0,1fr)_min(48rem,100%)_minmax(0,1fr)] gap-y-8 px-4 py-8"
    >
      <div class="col-start-2 row-start-1 flex flex-col gap-6">
        <header class="flex flex-col gap-3">
          <h1 class="text-3xl font-bold leading-tight">{title}</h1>

          <div class="flex items-center gap-2 text-sm text-muted-foreground">
            <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
            {readingTime && (
              <>
                <span aria-hidden="true">|</span>
                <span>{readingTime}</span>
              </>
            )}
            {updatedDate && (
              <>
                <span aria-hidden="true">|</span>
                <span>Aggiornato il {formatDate(updatedDate)}</span>
              </>
            )}
          </div>

          <Tags tags={tags} />
        </header>

        {
          heroImage && (
            <Image
              class="w-full rounded-xl"
              width={1020}
              height={510}
              src={heroImage}
              alt=""
            />
          )
        }

        {/* Navigazione (precedente / corso / successiva) sotto l'intestazione. */}
        <slot name="nav" />
      </div>

      {/* Sidebar di sinistra: indice del corso (slot) oppure indice semplice del post. */}
      {Astro.slots.has("sidebar-left") ? (
        <slot name="sidebar-left" />
      ) : (
        hasToc && (
          <aside class="col-start-1 row-start-2 hidden xl:block">
            <nav
              data-sidebar-scroll
              aria-label="Indice del post"
              class="sticky top-20 mr-8 ml-auto flex max-h-[calc(100vh-6rem)] max-w-80 flex-col overflow-y-auto pb-6"
            >
              <p class="mb-3 text-base font-medium text-foreground">Tabella dei contenuti</p>
              <TableOfContents items={tocItems} />
            </nav>
          </aside>
        )
      )}

      <article class="col-start-2 row-start-2 flex flex-col gap-6">
        <div class="prose">
          <slot />
        </div>

        {/* Contenuto extra dopo il corpo del post (es. elenco capitoli del corso). */}
        <slot name="after" />
      </article>

      {/* Sidebar di destra: directory del corso (slot, solo nelle pagine corso). */}
      <slot name="sidebar-right" />
    </main>
    <Footer />
  </body>
</html>

<script>
  // Centra `el` nel suo contenitore scrollabile della sidebar.
  function scrollIntoCenter(el: HTMLElement) {
    const scroller = el.closest<HTMLElement>("[data-sidebar-scroll]");
    if (!scroller) return;
    const s = scroller.getBoundingClientRect();
    const e = el.getBoundingClientRect();
    const delta = e.top - s.top - (scroller.clientHeight - e.height) / 2;
    if (Math.abs(delta) > 4) scroller.scrollTop += delta;
  }

  function initToc() {
    const links = document.querySelectorAll<HTMLElement>("[data-heading]");
    const headings = Array.from(
      document.querySelectorAll<HTMLElement>(".prose h2, .prose h3")
    );

    const current = document.getElementById("toc-current");
    const progress = document.getElementById("toc-progress") as SVGCircleElement | null;
    const CIRCUMFERENCE = 2 * Math.PI * 10;

    function updateProgress() {
      if (!progress) return;
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const pct = scrollable > 0 ? Math.min(Math.max(window.scrollY / scrollable, 0), 1) : 0;
      progress.style.strokeDashoffset = String(CIRCUMFERENCE * (1 - pct));
    }

    function setActive(id: string) {
      let activeText = "";
      links.forEach(link => {
        if (link.dataset.heading === id) {
          link.setAttribute("aria-current", "true");
          activeText = link.textContent?.trim() ?? "";
        } else {
          link.removeAttribute("aria-current");
        }
      });
      if (current && activeText) current.textContent = activeText;
      // Mantiene la sezione attiva visibile nella sidebar di sinistra.
      document
        .querySelectorAll<HTMLElement>('[data-sidebar-scroll] [data-heading][aria-current="true"]')
        .forEach(scrollIntoCenter);
    }

    let activeId: string | null = null;
    function onScroll() {
      if (headings.length) {
        let id = headings[0].id;
        for (const h of headings) {
          if (h.getBoundingClientRect().top <= 100) id = h.id;
        }
        if (id !== activeId) {
          activeId = id;
          setActive(id);
        }
      }
      updateProgress();
    }

    // Chiude la barra ripiegabile dopo aver scelto una sezione.
    const topToc = document.querySelector<HTMLDetailsElement>(".toc-top");
    topToc?.querySelectorAll("a").forEach(a => {
      a.addEventListener("click", () => {
        topToc.open = false;
      });
    });

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    // Autoscroll iniziale: centra il capitolo corrente (destra) e la sezione attiva (sinistra).
    requestAnimationFrame(() => {
      document
        .querySelectorAll<HTMLElement>('[data-sidebar-scroll] [data-current="true"]')
        .forEach(scrollIntoCenter);
      document
        .querySelectorAll<HTMLElement>('[data-sidebar-scroll] [data-heading][aria-current="true"]')
        .forEach(scrollIntoCenter);
    });

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", onScroll);
      },
      { once: true }
    );
  }

  document.addEventListener("astro:page-load", initToc);
</script>
