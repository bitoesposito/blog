---
import { getCollection } from "astro:content";
import Head from "../../components/Head.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE, NAV_LINKS } from "../../consts";

const education = (await getCollection("education")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<Head title={SITE.title} description={SITE.description} />
	</head>
	<body>
		<Header />
		<main class="mx-auto flex max-w-3xl flex-col gap-4 px-4 py-4">
			{education.length === 0 && (
				<p class="text-muted-foreground">Nessun post disponibile al momento.</p>
			)}
			
			<div class="flex flex-col gap-4">
				{education.map((edu) => (
				<article class="flex flex-col">
					<h2 class="text-xl font-bold">
						<a href={`/education/${edu.id}`} class="hover:underline">
							{edu.data.title}
						</a>
					</h2>
					<p class="text-sm text-muted-foreground">
						{edu.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</p>
					<p>{edu.data.description}</p>
				</article>
			))}
			</div>
		</main>
		<Footer />
	</body>
</html>
