---
import ListLayout from "../../layouts/ListLayout.astro";
import { PostCard } from "../../components/ui/post-card";
import { groupByYear } from "../../lib/post";
import { getCourses } from "../../lib/collections";
import { SITE } from "../../consts";

const courses = await getCourses();
const years = groupByYear(courses.map((c) => c.entry));

// id corso → { numero capitoli, corpo combinato (corso + capitoli) per il tempo di lettura }
const meta = new Map(
  courses.map((c) => [
    c.entry.id,
    {
      chapters: c.chapters.length,
      body: [c.entry.body, ...c.chapters.map((ch) => ch.body)].join(" "),
    },
  ])
);
---

<ListLayout title={`Formazione · ${SITE.title}`}>
  {
    courses.length === 0 ? (
      <p class="text-muted-foreground">Nessun contenuto disponibile al momento.</p>
    ) : (
      years.map(([year, items]) => (
        <section class="flex flex-col gap-3" aria-labelledby={`year-edu-${year}`}>
          <h2 id={`year-edu-${year}`} class="font-bold">
            {year}
          </h2>
          <div class="flex flex-col">
            {items.map((entry) => (
              <PostCard
                href={`/education/${entry.id}`}
                title={entry.data.title}
                description={entry.data.description}
                pubDate={entry.data.pubDate}
                body={meta.get(entry.id)!.body}
                chapters={meta.get(entry.id)!.chapters}
                tags={entry.data.tags}
              />
            ))}
          </div>
        </section>
      ))
    )
  }
</ListLayout>
