---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { PostCard } from "../../components/ui/post-card";
import { groupByYear } from "../../lib/post";
import { SITE } from "../../consts";

const education = (await getCollection("education")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const years = groupByYear(education);
---

<ListLayout title={`Formazione · ${SITE.title}`}>
  {
    education.length === 0 ? (
      <p class="text-muted-foreground">Nessun contenuto disponibile al momento.</p>
    ) : (
      years.map(([year, items]) => (
        <section class="flex flex-col gap-3" aria-labelledby={`year-edu-${year}`}>
          <h2 id={`year-edu-${year}`} class="font-bold">
            {year}
          </h2>
          <div class="flex flex-col">
            {items.map((edu) => (
              <PostCard
                href={`/education/${edu.id}`}
                title={edu.data.title}
                description={edu.data.description}
                pubDate={edu.data.pubDate}
                body={edu.body}
                tags={edu.data.tags}
              />
            ))}
          </div>
        </section>
      ))
    )
  }
</ListLayout>
