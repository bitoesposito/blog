---
import { getCollection } from "astro:content";
import Head from "../components/Head.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { Link } from "../components/ui/link";
import { buttonVariants } from "../components/ui/button";
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardContent,
} from "../components/ui/card";
import { Tags } from "../components/ui/tags";
import ProjectCard from "../components/ProjectCard.astro";
import { formatDate, readingTime } from "../lib/post";
import { getCourses } from "../lib/collections";
import { SITE } from "../consts";
import { Icon } from "@/components/ui/icon";
import { Image } from "astro:assets";
import heroImage from "../assets/static/00.png";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, SITE.featuredPostCount);

const projects = (await getCollection("projects"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, SITE.featuredProjectCount);

const courses = (await getCourses()).slice(0, SITE.featuredEducationCount);
---

<!doctype html>
<html lang="it">
  <head>
    <Head title={SITE.title} description={SITE.description} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: SITE.author,
      url: SITE.href,
      sameAs: [
        "https://github.com/bitoesposito",
        "https://www.linkedin.com/in/vitoespo/",
      ],
    })} />
  </head>
  <body>
    <Header />
    <main class="mx-auto flex max-w-3xl flex-col gap-8 px-4 lg:px-0 py-4">
      <!-- HERO -->
      <section
        id="hero"
        class="flex flex-col sm:flex-row gap-3 py-3 justify-between sm:items-center"
      >
        <div class="flex flex-col md:items-start items-center">
          <h1 class="font-light uppercase">Vito Esposito</h1>
          <Image
            src={heroImage}
            alt="Logo di Vito Esposito"
            width={592}
            height={118}
            loading="eager"
            fetchpriority="high"
            class="sm:w-[18.5rem] w-full h-auto"
          />
          <h1 class="text-2xl font-bold">DEVELOPER & DESIGNER</h1>
        </div>
        <div
          class="flex gap-3 grid grid-cols-2 md:justify-start justify-center"
        >
        <Link
          href="https://github.com/bitoesposito"
          icon="github"
          external
          aria-label="GitHub"
          className={buttonVariants({ variant: "outline" })}
        >
          GitHub
        </Link>
        <Link
          href="https://www.linkedin.com/in/vitoespo/"
          icon="linkedin"
          external
          aria-label="LinkedIn"
          className={buttonVariants({ variant: "outline" })}
        >
          LinkedIn
        </Link>
        <Link
          href="/CV.pdf"
          icon="FileText"
          aria-label="Curriculum"
          className={buttonVariants({ variant: "outline" })}
        >
          Curriculum
        </Link>
        <Link
          href="mailto:info@vitoesposito.it"
          icon="Mail"
          aria-label="Contattami via mail"
          className={buttonVariants({ variant: "outline" })}
        >
          Contattami
        </Link>
          <p class="text-xs leading-none flex gap-2 items-center col-span-2">
            <Icon name="MapPin" />WhereTech SRL - Rome [Italy]
          </p>
        </div>
      </section>

      <hr />

      <!-- ULTIMI POST -->
      <section id="latest-posts" class="flex flex-col gap-3">
        <div class="flex gap-3 justify-between">
          <h2 class="text-xl font-semibold">Ultimi post</h2>
          <Link
            href="/blog"
            className={buttonVariants({ variant: "outline" })}
            icon="ArrowRight"
            aria-label="Vedi tutti i post"
          >
            Vedi tutti
          </Link>
        </div>
        <div class="flex flex-col">
          {
            posts.length === 0 && (
              <p class="text-muted-foreground">
                Nessun post disponibile al momento.
              </p>
            )
          }
          {
            posts.map((post) => (
              <a href={`/blog/${post.id}`} class="block">
                <Card>
                  <CardHeader>
                    <CardTitle className="text-lg leading-[1.25]">
                      {post.data.title}
                    </CardTitle>
                    {post.data.description && (
                      <CardDescription className="line-clamp-3 leading-[1.25]">
                        {post.data.description}
                      </CardDescription>
                    )}
                  </CardHeader>
                  <CardContent className="flex sm:flex-row flex-col justify-between gap-3">
                    <div class="flex items-center gap-2 text-sm text-muted-foreground">
                      <time
                        class="whitespace-nowrap"
                        datetime={post.data.pubDate.toISOString()}
                      >
                        {formatDate(post.data.pubDate)}
                      </time>
                      <span aria-hidden="true">|</span>
                      <span class="whitespace-nowrap">
                        {readingTime(post.body)}
                      </span>
                    </div>
                    <Tags tags={post.data.tags} max={2} />
                  </CardContent>
                </Card>
              </a>
            ))
          }
        </div>
      </section>

      <!-- ULTIMI PROGETTI -->
      <section id="latest-projects" class="flex flex-col gap-3">
        <div class="flex gap-3 justify-between">
          <h2 class="text-xl font-semibold">Ultimi progetti</h2>
          <Link
            href="/projects"
            className={buttonVariants({ variant: "outline" })}
            icon="ArrowRight"
            aria-label="Vedi tutti i progetti"
          >
            Vedi tutti
          </Link>
        </div>
        <div class="flex flex-col gap-4">
          {
            projects.length === 0 && (
              <p class="text-muted-foreground">
                Nessun progetto disponibile al momento.
              </p>
            )
          }
          {
            projects.map((project) => (
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.data.title}
                description={project.data.description}
                pubDate={project.data.pubDate}
                tags={project.data.tags}
                image={project.data.heroImage}
              />
            ))
          }
        </div>
      </section>

      <!-- FORMAZIONE RECENTE -->
      <section id="latest-education" class="flex flex-col gap-3">
        <div class="flex gap-3 justify-between">
          <h2 class="text-xl font-semibold">Formazione recente</h2>
          <Link
            href="/education"
            className={buttonVariants({ variant: "outline" })}
            icon="ArrowRight"
            aria-label="Vedi tutta la formazione"
          >
            Vedi tutti
          </Link>
        </div>
        <div class="flex flex-col">
          {
            courses.length === 0 && (
              <p class="text-muted-foreground">
                Nessuna formazione disponibile al momento.
              </p>
            )
          }
          {
            courses.map(({ entry, chapters }) => (
              <a href={`/education/${entry.id}`} class="block">
                <Card>
                  <CardHeader>
                    <CardTitle className="text-lg leading-[1.25]">
                      {entry.data.title}
                    </CardTitle>
                    {entry.data.description && (
                      <CardDescription className="line-clamp-3 leading-[1.25]">
                        {entry.data.description}
                      </CardDescription>
                    )}
                  </CardHeader>
                  <CardContent className="flex flex-col gap-1">
                    <div class="flex items-center gap-2 text-sm text-muted-foreground">
                      <time datetime={entry.data.pubDate.toISOString()}>
                        {formatDate(entry.data.pubDate)}
                      </time>
                      {chapters.length > 0 && (
                        <>
                          <span aria-hidden="true">|</span>
                          <span>{chapters.length} lezioni</span>
                        </>
                      )}
                    </div>
                    <Tags tags={entry.data.tags} max={2} />
                  </CardContent>
                </Card>
              </a>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
