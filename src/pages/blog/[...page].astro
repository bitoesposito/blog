---
import type { GetStaticPaths, Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { PostCard } from "../../components/ui/post-card";
import { groupByYear } from "../../lib/post";
import { SITE } from "../../consts";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: SITE.postsPerPage });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<"blog">> };

const { page } = Astro.props;
const years = groupByYear(page.data);
---

<ListLayout
  title={`Blog · ${SITE.title}`}
  currentPage={page.currentPage}
  totalPages={page.lastPage}
>
  {
    page.data.length === 0 ? (
      <p class="text-muted-foreground">Nessun post disponibile al momento.</p>
    ) : (
      years.map(([year, posts]) => (
        <section class="flex flex-col gap-3" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`} class="font-bold">
            {year}
          </h2>
          <div class="flex flex-col">
            {posts.map((post) => (
              <PostCard
                href={`/blog/${post.id}`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                body={post.body}
                tags={post.data.tags}
              />
            ))}
          </div>
        </section>
      ))
    )
  }
</ListLayout>
