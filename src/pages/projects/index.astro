---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { groupByYear } from "../../lib/post";
import { SITE } from "../../consts";

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const years = groupByYear(projects);
---

<ListLayout title={`Progetti · ${SITE.title}`}>
  {
    projects.length === 0 ? (
      <p class="text-muted-foreground">Nessun progetto disponibile al momento.</p>
    ) : (
      years.map(([year, items]) => (
        <section class="flex flex-col gap-3" aria-labelledby={`year-proj-${year}`}>
          <h2 id={`year-proj-${year}`} class="font-bold">
            {year}
          </h2>
          <div class="flex flex-col gap-4">
            {items.map((project) => (
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.data.title}
                description={project.data.description}
                pubDate={project.data.pubDate}
                tags={project.data.tags}
                image={project.data.heroImage}
              />
            ))}
          </div>
        </section>
      ))
    )
  }
</ListLayout>
