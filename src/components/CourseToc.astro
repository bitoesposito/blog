---
import type { TocSection } from "@/lib/collections";

interface Props {
  base: string;
  parent: TocSection;
  subposts: TocSection[];
}

const { base, parent, subposts } = Astro.props;

const linkClass =
  "block py-1 text-sm leading-snug text-muted-foreground no-underline transition-colors hover:text-foreground aria-[current=true]:font-medium aria-[current=true]:text-foreground";
---

<aside class="col-start-1 row-start-2 hidden xl:block">
  <nav
    data-sidebar-scroll
    aria-label="Indice del corso"
    class="sticky top-20 mr-8 ml-auto flex max-h-[calc(100vh-6rem)] max-w-80 flex-col gap-2 overflow-y-auto pb-6"
  >
    <p class="text-base font-medium text-foreground">Tabella dei contenuti</p>

    {parent.headings.length > 0 && (
      <ul class="m-0 flex list-none flex-col p-0">
        {parent.headings.map((h) => (
          <li>
            <a
              href={parent.current ? `#${h.slug}` : `${base}/${parent.id}#${h.slug}`}
              data-heading={parent.current ? h.slug : undefined}
              class:list={[linkClass, h.depth === 3 && "pl-3"]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    )}

    {subposts.length > 0 && (
      <div class="mt-1 flex items-center gap-2">
        <span class="h-px flex-1 bg-border"></span>
        <span class="text-xs font-medium tracking-wide text-muted-foreground uppercase">Lezioni</span>
        <span class="h-px flex-1 bg-border"></span>
      </div>
    )}

    {subposts.map((section) => (
      <div
        class:list={[
          "rounded-lg border border-border p-2 transition-colors",
          section.current && "bg-muted/50",
        ]}
      >
        <a
          href={section.current ? "#" : `${base}/${section.id}`}
          class:list={[
            "block text-sm font-medium no-underline transition-colors hover:text-foreground",
            section.current ? "text-foreground" : "text-muted-foreground",
          ]}
        >
          {section.title}
        </a>
        {section.headings.length > 0 && (
          <ul class="m-0 mt-1 flex list-none flex-col p-0">
            {section.headings.map((h) => (
              <li>
                <a
                  href={section.current ? `#${h.slug}` : `${base}/${section.id}#${h.slug}`}
                  data-heading={section.current ? h.slug : undefined}
                  class:list={[linkClass, h.depth === 3 && "pl-3"]}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </nav>
</aside>
